rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection: each user can read/write their own document only
    match /users/{userId} {
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Bookings collection: authenticated users can read all
    //   create: booking owner only
    //   update: booking owner OR admin
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (
        request.resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
      allow delete: if false;
    }

    // Office rentals
    match /officeRentals/{rentalId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Receipts: authenticated users can read all, create their own
    match /receipts/{receiptId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // Payments: authenticated users can read all, create their own
    match /payments/{paymentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // Payment proofs
    match /paymentProofs/{proofId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // Chat messages
    match /chatMessages/{messageId} {
      allow read, write: if request.auth != null;
    }

    // Unread counts
    match /unreadCounts/{scope} {
      allow read, write: if request.auth != null;
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Maintenance records: authenticated users can read all
    match /maintenanceRecords/{recordId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // CMS
    match /cms/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Contracts
    match /contracts/{contractId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // All other collections — locked down
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
